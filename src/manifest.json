{
    "manifest_version": 3,
    "name": "Lead Extraction Engine",
    "version": "1.0.0",
    "description": "Professional B2B/B2C Lead Extraction Engine. Extract leads from Google Maps, Justdial, LinkedIn, Yelp, and 200+ directories.",
    "permissions": [
        "storage",
        "unlimitedStorage",
        "scripting",
        "activeTab",
        "notifications"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup/index.html",
        "default_icon": {
            "16": "assets/icon16.png",
            "48": "assets/icon48.png",
            "128": "assets/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content/injector.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.google.com/maps/*",
                "https://www.google.co.in/maps/*",
                "https://www.google.co.uk/maps/*",
                "https://www.google.ca/maps/*",
                "https://www.google.com.au/maps/*",
                "https://maps.google.com/*"
            ],
            "js": [
                "content/extractors/google_maps.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.linkedin.com/*",
                "https://linkedin.com/*"
            ],
            "js": [
                "content/extractors/linkedin.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.zillow.com/*",
                "https://zillow.com/*"
            ],
            "js": [
                "content/extractors/zillow.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "content/extractors/*.js",
                "common/*.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "icons": {
        "16": "assets/icon16.png",
        "48": "assets/icon48.png",
        "128": "assets/icon128.png"
    }
}